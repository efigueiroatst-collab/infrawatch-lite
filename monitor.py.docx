import psutil
import time
from datetime import datetime

while True:
    cpu = psutil.cpu_percent(interval=1)
    mem = psutil.virtual_memory().percent
    disk = psutil.disk_usage('/').percent
    now = datetime.now().strftime("%H:%M:%S")

    html = f"""
    <!DOCTYPE html>
    <html lang="pt-br">
    <head>
    <meta charset="UTF-8">
    <meta http-equiv="refresh" content="2">
    <title>InfraWatch Lite</title>

    <style>
    body {{
        background-color: #0d1117;
        color: #58a6ff;
        font-family: Arial, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        margin: 0;
    }}

    .container {{
        background: #161b22;
        padding: 30px;
        border-radius: 12px;
        width: 320px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.5);
        text-align: center;
    }}

    h1 {{
        color: #ffffff;
        margin-bottom: 20px;
    }}

    .stat {{
        margin: 15px 0;
        font-size: 18px;
    }}

    .footer {{
        margin-top: 20px;
        font-size: 12px;
        color: #8b949e;
    }}
    </style>
    </head>

    <body>

    <div class="container">
        <h1>InfraWatch Lite</h1>

        <div class="stat">CPU: {cpu}%</div>
        <div class="stat">Memória: {mem}%</div>
        <div class="stat">Disco: {disk}%</div>

        <div class="footer">Atualizado: {now}</div>
    </div>

    </body>
    </html>
    """

    with open("index.html", "w", encoding="utf-8") as f:
        f.write(html)

    print(f"CPU: {cpu}% | RAM: {mem}% | DISK: {disk}%")

    time.sleep(2)